rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function myRole() { return signedIn() ? myProfile().data.role : null; }
    function isOwner() { return myRole() == 'OWNER'; }
    function isAdminOrOwner() { return myRole() == 'ADMIN' || myRole() == 'OWNER'; }

    // Workspace-wide settings (auth config, notification config, restrictions)
    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // User profiles: everyone signed in can see the directory (needed to
    // render names/roles in the UI); only the owner can create/edit/remove.
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // Groups: readable by anyone signed in, only the owner can manage them.
    match /groups/{groupId} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // Access requests: admins create them, owner resolves them.
    match /requests/{requestId} {
      allow read: if isAdminOrOwner();
      allow create: if isAdminOrOwner();
      allow update, delete: if isOwner();
    }

    // File metadata: everyone signed in can read (folder-level filtering
    // happens in the UI); only non-clients can create/delete.
    match /files/{fileId} {
      allow read: if signedIn();
      allow create, delete: if signedIn() && myRole() != 'CLIENT';
      allow update: if isAdminOrOwner();
    }

    // People directory: internal staff records, not visible to clients.
    // Only the owner/admins can add, edit, or remove entries.
    match /people/{personId} {
      allow read: if signedIn() && myRole() != 'CLIENT';
      allow write: if isAdminOrOwner();
    }

    // Time-tracking entries (clock in/out sessions). Everyone manages their
    // own; only the owner can read or edit anyone else's. Clients never use
    // this feature at all, enforced both here and in the UI.
    match /time-entries/{entryId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isOwner());
      allow create: if signedIn() && myRole() != 'CLIENT' && (request.resource.data.userId == request.auth.uid || isOwner());
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isOwner());
      allow delete: if isOwner();
    }

    // Leave requests: an Employee/Admin files one for themselves (never the
    // Owner, who has no personal schedule to take leave from). The
    // Admin-then-Owner approval chain is enforced by the app via the
    // status field (pending_admin -> pending_owner -> approved/denied) —
    // this rule just gates who can read/write the underlying doc: the
    // requester (to view their own and cancel it) or any Admin/Owner (to
    // review and decide).
    match /leave-requests/{requestId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow create: if signedIn() && myRole() != 'CLIENT' && myRole() != 'OWNER' && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow delete: if isOwner();
    }
  }
}
