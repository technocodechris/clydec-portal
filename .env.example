# --- Client-side: Firebase (always needed) ---
# Copy this file to .env and fill in values from:
# Firebase Console > Project settings > General > Your apps > SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Which file-storage backend to use: "firebase" (default) or "drive"
VITE_STORAGE_PROVIDER=firebase

# --- Server-side (only needed if VITE_STORAGE_PROVIDER=drive) ---
# These power the /api/drive-* functions and must be set as environment
# variables on your hosting platform (Vercel/Netlify dashboard), never
# committed here, since they're secret keys. See README "Google Drive setup".
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
GDRIVE_CLIENT_EMAIL=
GDRIVE_PRIVATE_KEY=
GDRIVE_FOLDER_CREATIVE=
GDRIVE_FOLDER_DATA=
GDRIVE_FOLDER_FINANCE=
GDRIVE_FOLDER_CLIENT_AURORA=
